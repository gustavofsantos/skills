#!/bin/bash
# Auto-bump plugin patch version if unchanged since HEAD

PLUGIN_JSON=".claude-plugin/plugin.json"

if git rev-parse --verify HEAD >/dev/null 2>&1; then
    HEAD_VERSION=$(git show HEAD:"$PLUGIN_JSON" 2>/dev/null | python3 -c "import sys,json; print(json.load(sys.stdin).get('version',''))" 2>/dev/null)
else
    HEAD_VERSION=""
fi

CURRENT_VERSION=$(python3 -c "import json; print(json.load(open('$PLUGIN_JSON')).get('version',''))" 2>/dev/null)

if [ "$CURRENT_VERSION" = "$HEAD_VERSION" ] || [ -z "$CURRENT_VERSION" ]; then
    if [ -z "$CURRENT_VERSION" ]; then
        NEW_VERSION="1.0.0"
    else
        NEW_VERSION=$(python3 -c "v='$CURRENT_VERSION'.split('.'); v[2]=str(int(v[2])+1); print('.'.join(v))")
    fi

    python3 - "$PLUGIN_JSON" "$NEW_VERSION" <<'EOF'
import json, sys
path, version = sys.argv[1], sys.argv[2]
with open(path) as f:
    d = json.load(f)
d["version"] = version
with open(path, "w") as f:
    json.dump(d, f, indent=2)
    f.write("\n")
EOF

    git add "$PLUGIN_JSON"
    echo "auto-bumped plugin version: $CURRENT_VERSION → $NEW_VERSION"
fi
