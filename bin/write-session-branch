#!/usr/bin/env python3
"""
write-session-branch <session-slug>

Reads SESSION.md content from stdin. Writes it to the personal sessions orphan
branch using git plumbing — no working tree changes, no HEAD movement.

Prints "<branch>:<slug>/SESSION.md" on success.
Branch name is derived from git config user.name.
"""
import subprocess
import sys
import re


def run(*args, input=None, check=True):
    result = subprocess.run(
        list(args),
        input=input,
        capture_output=True,
        text=True,
    )
    if check and result.returncode != 0:
        msg = result.stderr.strip() or result.stdout.strip()
        print(f"git error ({args[0]}): {msg}", file=sys.stderr)
        sys.exit(1)
    return result.stdout.strip()


def branch_exists(branch):
    r = subprocess.run(
        ["git", "rev-parse", "--verify", branch],
        capture_output=True,
    )
    return r.returncode == 0


def derive_branch():
    username = run("git", "config", "user.name")
    slug = re.sub(r"[^a-z0-9]+", "-", username.lower()).strip("-")
    return f"{slug}/sessions"


def main():
    if len(sys.argv) < 2:
        print("Usage: write-session-branch <session-slug>", file=sys.stderr)
        sys.exit(1)

    session_slug = sys.argv[1]
    content = sys.stdin.read()

    if not content.strip():
        print("Error: SESSION.md content is empty", file=sys.stderr)
        sys.exit(1)

    branch = derive_branch()

    # 1. Write SESSION.md blob
    blob = run("git", "hash-object", "-w", "--stdin", input=content)

    # 2. Build session subtree: single file SESSION.md
    session_tree = run(
        "git", "mktree",
        input=f"100644 blob {blob}\tSESSION.md\n",
    )

    # 3. Build root tree: existing entries + new session directory
    if branch_exists(branch):
        existing = run("git", "ls-tree", branch)
        root_input = existing + f"\n040000 tree {session_tree}\t{session_slug}\n"
    else:
        root_input = f"040000 tree {session_tree}\t{session_slug}\n"

    root_tree = run("git", "mktree", input=root_input)

    # 4. Create commit
    commit_args = ["git", "commit-tree", root_tree]
    if branch_exists(branch):
        parent = run("git", "rev-parse", branch)
        commit_args += ["-p", parent]
    commit_args += ["-m", f"session: {session_slug}"]

    commit = run(*commit_args)

    # 5. Advance the branch ref
    run("git", "update-ref", f"refs/heads/{branch}", commit)

    print(f"{branch}:{session_slug}/SESSION.md")


if __name__ == "__main__":
    main()
